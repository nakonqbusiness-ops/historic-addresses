# ─── Secrets — NEVER commit ───
.env
.env.*
*.pem
*.key

# ─── Database (lives on the Railway Volume, not in git) ───
# NB: data/ is NOT ignored — it holds data/people.js (seed source the app reads).
# Database files are excluded by name so they stay out even if placed under data/.
database.db
database.db-shm
database.db-wal
*.sqlite
*.sqlite3

# ─── Local uploads (served from the Volume in production) ───
uploads/

# ─── Dependencies / build ───
node_modules/
npm-debug.log*
yarn-error.log*

# ─── OS / editor cruft ───
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/

# Local Claude Code dev config (preview/launch)
.claude/
